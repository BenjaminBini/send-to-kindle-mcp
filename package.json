{
  "name": "send-to-kindle-mcp",
  "version": "1.0.0",
  "description": "MCP server that sends EPUB (and other supported document) files to a Kindle device via Amazon's Send-to-Kindle email feature.",
  "type": "module",
  "license": "MIT",
  "author": "Benjamin Bini",
  "homepage": "https://github.com/BenjaminBini/send-to-kindle-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BenjaminBini/send-to-kindle-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/BenjaminBini/send-to-kindle-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "kindle",
    "send-to-kindle",
    "epub",
    "ebook",
    "amazon"
  ],
  "bin": {
    "send-to-kindle-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "nodemailer": "^6.9.16",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
