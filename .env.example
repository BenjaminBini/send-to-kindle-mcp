# --- SMTP (outgoing email) configuration ---
# Example below is for Gmail. Use an "App Password", NOT your normal password.
# (Google Account > Security > 2-Step Verification > App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# secure: leave unset to auto-pick (true for port 465, false for 587/STARTTLS)
# SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
# Address shown as the sender. Must be on Amazon's Approved Personal Document
# E-mail List. Defaults to SMTP_USER if unset.
SMTP_FROM=you@gmail.com

# --- Kindle destination ---
# Your device's Send-to-Kindle address (Manage Your Content and Devices >
# Devices > your Kindle > shows the @kindle.com address).
KINDLE_EMAIL=you_abc123@kindle.com
